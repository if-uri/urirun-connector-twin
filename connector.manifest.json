      "kind": "local-function",
      "adapter": "local-function-subprocess",
      "python": {
        "type": "python",
        "module": "urirun_connector_twin.core",
        "export": "sandbox_probe"
      },
      "policy": {
        "allowExecute": true
      },
      "meta": {
        "connector": "twin",
        "label": "Prove reversibility in a disposable Docker sandbox"
      },
      "inputSchema": {
        "properties": {
          "image": {
            "default": "alpine:3",
